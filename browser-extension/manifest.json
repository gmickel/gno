{
  "manifest_version": 3,
  "name": "GNO Browser Clipper",
  "description": "Capture explicitly selected or visible page content into local GNO.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "preview.html",
    "default_title": "Capture with GNO"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src http://127.0.0.1:*"
  }
}
