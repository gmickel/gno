{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GNO Expansion Training Example",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "query", "source", "target"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "query": { "type": "string", "minLength": 1 },
    "lang": { "type": "string", "minLength": 2 },
    "intent": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "enum": ["handcrafted", "synthetic", "distilled", "imported"]
        },
        "name": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "quotedPhrases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "negations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "criticalEntities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "retrievalTargets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relevantDocs", "judgments"],
      "properties": {
        "relevantDocs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "judgments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["docid", "relevance"],
            "properties": {
              "docid": { "type": "string", "minLength": 1 },
              "relevance": { "type": "integer", "minimum": 1, "maximum": 3 }
            }
          }
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lexicalQueries", "vectorQueries"],
      "properties": {
        "lexicalQueries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "vectorQueries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "hyde": {
          "type": "string",
          "minLength": 32,
          "maxLength": 512
        }
      }
    }
  }
}
