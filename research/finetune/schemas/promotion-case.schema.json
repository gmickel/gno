{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GNO Promotion Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "split",
    "caseSet",
    "category",
    "query",
    "relevantDocs",
    "judgments"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "split": { "enum": ["train", "validation", "heldout"] },
    "caseSet": { "enum": ["baseline", "adversarial", "multilingual", "ask"] },
    "category": { "type": "string", "minLength": 1 },
    "query": { "type": "string", "minLength": 1 },
    "lang": { "type": "string", "minLength": 2 },
    "queryModes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "text"],
        "properties": {
          "mode": { "enum": ["term", "intent", "hyde"] },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "relevantDocs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "judgments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["docid", "relevance"],
        "properties": {
          "docid": { "type": "string", "minLength": 1 },
          "relevance": { "type": "integer", "minimum": 1, "maximum": 3 }
        }
      }
    },
    "smokeTags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sourceFixture": { "type": "string", "minLength": 1 }
  }
}
