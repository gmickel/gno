{
  "id": "gno-autonomous-expansion-v1",
  "task": "expansion",
  "sandboxRoot": "research/finetune",
  "allowedRoots": [
    "research/finetune/",
    "research/finetune/configs/",
    "research/finetune/contracts/",
    "research/finetune/data/training/",
    "research/finetune/scripts/",
    "research/finetune/autonomous/"
  ],
  "mutationTargets": [
    "research/finetune/configs/mlx-qwen3-1.7b-lora.yaml",
    "research/finetune/configs/training-mix.json",
    "research/finetune/configs/mixes/",
    "research/finetune/configs/prompt-profile.json",
    "research/finetune/configs/prompt-profiles/",
    "research/finetune/contracts/reward-contract.md",
    "research/finetune/README.md"
  ],
  "disallowedRoots": [
    "src/",
    "docs/",
    "spec/output-schemas/",
    "evals/fixtures/",
    "website/"
  ],
  "budget": {
    "maxRuntimeMinutes": 20,
    "maxChangedFiles": 4,
    "maxRunsPerSession": 3,
    "maxCommitsPerRun": 1
  },
  "metric": {
    "baselineArtifact": "evals/fixtures/retrieval-candidate-benchmark/latest.json",
    "validationCommand": "bun run research:finetune:validate",
    "smokeCommand": "bun test test/research/finetune-sandbox.test.ts",
    "promotionSplit": "heldout",
    "decision": {
      "primary": "retrieval",
      "weights": {
        "ndcgAt10": 1000,
        "schemaSuccessRate": 120,
        "askRecallAt5": 25,
        "p95Ms": -0.01
      },
      "minimums": {
        "ndcgDelta": 0.005,
        "schemaDelta": 0
      }
    }
  },
  "logging": {
    "runDir": "research/finetune/autonomous/runs",
    "requiredFields": [
      "experimentId",
      "commitSha",
      "changedFiles",
      "metricCommand",
      "decision",
      "runtimeSeconds"
    ]
  },
  "search": {
    "referenceRun": "auto-entity-lock-default-mix-lr95",
    "referenceBestValLoss": 0.31,
    "earlyStop": {
      "enabled": true,
      "minIteration": 500,
      "maxBestValLoss": 0.5,
      "maxValLossDelta": 0.22
    }
  },
  "promotion": {
    "humanApprovalRequired": true,
    "rollbackOnRegression": true
  }
}
