{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gno://schemas/activation-verification@1.0",
  "title": "GNO Activation Verification Receipt",
  "description": "Privacy-bounded proof that one collection can retrieve a corpus-derived result locally and, when requested, through one connector target.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "collection",
    "fingerprint",
    "ready",
    "generatedAt",
    "stages",
    "evidence"
  ],
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "ready": {
            "const": true
          }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "stages": {
            "type": "object",
            "properties": {
              "index": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "passed"
                  }
                }
              },
              "lexical": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "passed"
                  }
                }
              }
            }
          },
          "evidence": {
            "type": "object",
            "properties": {
              "probeHash": {},
              "resultUri": {},
              "resultSourceHash": {}
            },
            "required": ["probeHash", "resultUri", "resultSourceHash"]
          }
        }
      },
      "else": {
        "type": "object",
        "properties": {
          "stages": {
            "type": "object",
            "not": {
              "type": "object",
              "properties": {
                "index": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "const": "passed"
                    }
                  }
                },
                "lexical": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "const": "passed"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "stages": {
            "type": "object",
            "properties": {
              "connector": {
                "type": "object",
                "anyOf": [
                  {
                    "properties": {
                      "status": { "enum": ["passed", "failed"] }
                    }
                  },
                  {
                    "required": ["code"],
                    "properties": {
                      "code": { "not": { "const": "connector_not_requested" } }
                    }
                  }
                ]
              }
            }
          }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "evidence": {
            "type": "object",
            "properties": {
              "connectorTarget": { "type": "string" }
            },
            "required": ["connectorTarget"]
          }
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "collection": { "type": "string", "minLength": 1, "maxLength": 128 },
    "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ready": { "type": "boolean" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "stages": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "lexical", "semantic", "connector"],
      "properties": {
        "index": { "$ref": "#/definitions/stage" },
        "lexical": { "$ref": "#/definitions/stage" },
        "semantic": { "$ref": "#/definitions/stage" },
        "connector": { "$ref": "#/definitions/stage" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "probeHash": {
          "type": "string",
          "description": "Corpus-keyed probe digest; the raw probe term and key are not persisted.",
          "pattern": "^[a-f0-9]{64}$"
        },
        "resultUri": {
          "type": "string",
          "pattern": "^gno://[^/]+/.+",
          "maxLength": 2048
        },
        "resultSourceHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "connectorTarget": { "type": "string", "maxLength": 256 }
      }
    }
  },
  "definitions": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "startedAt", "completedAt", "latencyMs"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "pending", "failed", "skipped"]
        },
        "startedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "completedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "latencyMs": { "type": ["integer", "null"], "minimum": 0 },
        "code": {
          "type": "string",
          "enum": [
            "no_documents",
            "no_probe_term",
            "index_query_failed",
            "retrieval_mismatch",
            "semantic_not_checked",
            "connector_not_requested",
            "connector_not_configured",
            "connector_probe_unavailable",
            "connector_unsupported_config",
            "connector_start_failed",
            "connector_timeout",
            "connector_missing_tools",
            "connector_status_failed",
            "connector_search_failed",
            "connector_result_mismatch",
            "target_runtime_unverifiable"
          ]
        }
      }
    }
  }
}
