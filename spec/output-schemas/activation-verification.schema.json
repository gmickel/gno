{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gno://schemas/activation-verification@1.0",
  "title": "GNO Activation Verification Receipt",
  "description": "Privacy-bounded proof that one collection can retrieve a corpus-derived lexical result.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "collection",
    "fingerprint",
    "ready",
    "generatedAt",
    "stages",
    "evidence"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "collection": { "type": "string", "minLength": 1, "maxLength": 128 },
    "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ready": { "type": "boolean" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "stages": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "lexical", "semantic", "connector"],
      "properties": {
        "index": { "$ref": "#/definitions/stage" },
        "lexical": { "$ref": "#/definitions/stage" },
        "semantic": { "$ref": "#/definitions/stage" },
        "connector": { "$ref": "#/definitions/stage" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "probeHash": {
          "type": "string",
          "description": "Corpus-keyed probe digest; the raw probe term and key are not persisted.",
          "pattern": "^[a-f0-9]{64}$"
        },
        "resultUri": {
          "type": "string",
          "pattern": "^gno://[^/]+/.+",
          "maxLength": 2048
        },
        "resultSourceHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "connectorTarget": { "type": "string", "maxLength": 256 }
      }
    }
  },
  "definitions": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "startedAt", "completedAt", "latencyMs"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "pending", "failed", "skipped"]
        },
        "startedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "completedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "latencyMs": { "type": ["integer", "null"], "minimum": 0 },
        "code": {
          "type": "string",
          "enum": [
            "no_documents",
            "no_probe_term",
            "index_query_failed",
            "retrieval_mismatch",
            "semantic_not_checked",
            "connector_not_requested"
          ]
        }
      }
    }
  }
}
