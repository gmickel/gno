{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gno://schemas/status@1.0",
  "title": "GNO Status",
  "description": "Index status and health information",
  "type": "object",
  "required": [
    "indexName",
    "collections",
    "totalDocuments",
    "totalChunks",
    "embeddingBacklog",
    "healthy",
    "recentErrors",
    "activePreset",
    "capabilities",
    "onboarding",
    "health",
    "background"
  ],
  "properties": {
    "indexName": {
      "type": "string",
      "description": "Name of the index"
    },
    "configPath": {
      "type": "string",
      "description": "Path to config file"
    },
    "dbPath": {
      "type": "string",
      "description": "Path to SQLite database"
    },
    "collections": {
      "type": "array",
      "description": "Collection statistics",
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "documentCount",
          "chunkCount",
          "embeddedCount"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Collection name"
          },
          "path": {
            "type": "string",
            "description": "Collection root path"
          },
          "documentCount": {
            "type": "integer",
            "description": "Number of active documents",
            "minimum": 0
          },
          "chunkCount": {
            "type": "integer",
            "description": "Number of content chunks",
            "minimum": 0
          },
          "embeddedCount": {
            "type": "integer",
            "description": "Number of chunks with embeddings",
            "minimum": 0
          }
        }
      }
    },
    "totalDocuments": {
      "type": "integer",
      "description": "Total documents across all collections",
      "minimum": 0
    },
    "totalChunks": {
      "type": "integer",
      "description": "Total chunks across all collections",
      "minimum": 0
    },
    "embeddingBacklog": {
      "type": "integer",
      "description": "Chunks awaiting embedding",
      "minimum": 0
    },
    "recentErrors": {
      "type": "integer",
      "description": "Recent ingest errors in the last 24 hours",
      "minimum": 0
    },
    "lastUpdated": {
      "type": ["string", "null"],
      "description": "Last index update time (ISO 8601)",
      "format": "date-time"
    },
    "healthy": {
      "type": "boolean",
      "description": "Overall health status"
    },
    "activePreset": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "capabilities": {
      "type": "object",
      "required": ["bm25", "vector", "hybrid", "answer"],
      "properties": {
        "bm25": {
          "type": "boolean"
        },
        "vector": {
          "type": "boolean"
        },
        "hybrid": {
          "type": "boolean"
        },
        "answer": {
          "type": "boolean"
        }
      }
    },
    "onboarding": {
      "type": "object",
      "required": [
        "ready",
        "stage",
        "headline",
        "detail",
        "suggestedCollections",
        "steps"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "stage": {
          "type": "string",
          "enum": ["add-collection", "models", "indexing", "ready"]
        },
        "headline": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "suggestedCollections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "path", "reason"],
            "properties": {
              "label": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "status", "detail"],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["complete", "current", "upcoming"]
              },
              "detail": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "health": {
      "type": "object",
      "required": ["state", "summary", "checks"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["healthy", "needs-attention", "setup-required"]
        },
        "summary": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "status", "summary", "detail"],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["ok", "warn", "error"]
              },
              "summary": {
                "type": "string"
              },
              "detail": {
                "type": "string"
              },
              "actionLabel": {
                "type": "string"
              },
              "actionKind": {
                "type": "string",
                "enum": [
                  "add-collection",
                  "open-collections",
                  "sync",
                  "download-models",
                  "free-space"
                ]
              }
            }
          }
        }
      }
    },
    "background": {
      "type": "object",
      "required": ["watcher", "embedding", "events"],
      "properties": {
        "watcher": {
          "type": "object",
          "required": [
            "expectedCollections",
            "activeCollections",
            "failedCollections",
            "queuedCollections",
            "syncingCollections",
            "lastEventAt",
            "lastSyncAt"
          ],
          "properties": {
            "expectedCollections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "activeCollections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "failedCollections": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["collection", "reason"],
                "properties": {
                  "collection": { "type": "string" },
                  "reason": { "type": "string" }
                }
              }
            },
            "queuedCollections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "syncingCollections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "lastEventAt": {
              "type": ["string", "null"],
              "format": "date-time"
            },
            "lastSyncAt": {
              "type": ["string", "null"],
              "format": "date-time"
            }
          }
        },
        "embedding": {
          "type": "object",
          "required": [
            "available",
            "pendingDocCount",
            "running",
            "nextRunAt",
            "lastRunAt",
            "lastResult"
          ],
          "properties": {
            "available": { "type": "boolean" },
            "pendingDocCount": {
              "type": "integer",
              "minimum": 0
            },
            "running": { "type": "boolean" },
            "nextRunAt": { "type": ["integer", "null"] },
            "lastRunAt": { "type": ["integer", "null"] },
            "lastResult": {
              "type": ["object", "null"],
              "required": ["embedded", "errors"],
              "properties": {
                "embedded": {
                  "type": "integer",
                  "minimum": 0
                },
                "errors": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        },
        "events": {
          "type": "object",
          "required": ["connectedClients", "retryMs"],
          "properties": {
            "connectedClients": {
              "type": "integer",
              "minimum": 0
            },
            "retryMs": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
