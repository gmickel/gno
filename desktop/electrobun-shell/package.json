{
  "name": "gno-electrobun-shell",
  "version": "0.0.0",
  "private": true,
  "description": "Electrobun shell scaffold for the existing GNO workspace",
  "type": "module",
  "scripts": {
    "start": "electrobun dev",
    "dev": "electrobun dev --watch",
    "build": "electrobun build",
    "verify:packaged-runtime": "bun run scripts/verify-packaged-runtime.ts",
    "release:macos": "bun run scripts/release-macos.ts"
  },
  "dependencies": {
    "electrobun": "1.16.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
